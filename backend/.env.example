# Copy this to .env and fill in your values
# Never commit .env to GitHub

GROQ_API_KEY=gsk_your_key_here

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=https://your-project.vercel.app,http://localhost:5500,http://127.0.0.1:5500

# Session expiry in seconds (default 1 hour)
SESSION_TTL=3600
